{
  "name": "@geonovum/workflow-build-runner",
  "version": "0.3.0",
  "description": "Workflow build runner for JavaScript build definitions and XSLT-based document workflows.",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./cli": "./src/cli.js"
  },
  "bin": {
    "workflow-build-runner": "bin/workflow-build-runner.js"
  },
  "files": [
    "bin",
    "src",
    "index.js",
    "README.md"
  ],
  "scripts": {
    "build": "npm run prepublish:check",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "node --test tests/*.test.js",
    "pack:check": "npm pack --dry-run --cache .npm-cache",
    "prepublish:check": "npm run lint && npm test && npm run pack:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "keywords": [
    "workflow",
    "build",
    "runner",
    "xml",
    "xslt"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.5",
    "saxon-js": "^2.7.0",
    "xslt3": "^2.7.0",
    "zip-lib": "^1.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0"
  }
}
